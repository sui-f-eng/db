{
  "manifest_version": 3,
  "name": "豆包答题助手",
  "version": "1.6.3",
  "description": "头歌练习页自动识别题目、调用豆包 API 答题并跳转下一题",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": [
    "<all_urls>",
    "https://ark.cn-beijing.volces.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://172.16.36.150/classrooms/*/exercise/*",
        "https://www.educoder.net/classrooms/*/exercise/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
