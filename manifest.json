{
  "manifest_version": 3,
  "name": "suif",
  "version": "1.3.2",
  "description": "suif_nb",
  "permissions": ["storage", "tabs", "clipboardWrite"],
  "host_permissions": [
    "<all_urls>",
    "https://ark.cn-beijing.volces.com/*"
  ],
  "background": {
    "service_worker": "assistant.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.educoder.net/*", "*://172.16.36.150/*"],
      "js": ["educoder-copy.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["assistant.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
